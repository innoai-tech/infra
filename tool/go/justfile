export INFRA_CLI_DEBUG := "1"

# Install and normalize Go module dependencies.
[no-cd]
dep:
    go mod tidy

# Update direct and indirect Go dependencies.
[no-cd]
update:
    go get -u ./...

# Run the default test suite.
[no-cd]
test path='./...' *args:
    go test -count=1 -failfast {{ args }} {{ path }}

# Check coverage for the current public core packages.
[no-cd]
cover-core:
    go test -cover ./pkg/appinfo ./pkg/agent ./pkg/cli ./pkg/configuration ./pkg/cron ./pkg/http/webapp

# Apply repository formatting and generated fixes.
[no-cd]
fmt path='./...':
    go tool fmt {{ path }}

# Check exported docs on public root packages.
[no-cd]
doc-check:
    go tool exported-docs-check

# Regenerate example application outputs.
[no-cd]
gen path='./...' *args:
    go generate {{ args }} {{ path }}

# Regenerate public root packages and tools.
[no-cd]
gen-root:
    go generate ./pkg/... ./devpkg/... ./tool/...

# Regenerate the recommended example application.
[no-cd]
gen-example:
    go generate ./internal/example/...

# Install skill symlinks from go.mod annotated dependencies.
[no-cd]
skills-install:
    go tool skills-install
